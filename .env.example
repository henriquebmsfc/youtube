# ============================================================
# YouTube Analyzer — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# (o .env NÃO deve ir para o repositório — adicione ao .gitignore)
# ============================================================

# YouTube Data API v3
YOUTUBE_API_KEY=

# Anthropic (Claude) — https://console.anthropic.com
ANTHROPIC_API_KEY=

# GenAIPro — https://genaipro.vn (JWT token)
GENAIPRO_API_KEY=

# Voz padrão ElevenLabs (via GenAIPro)
DEFAULT_VOICE_ID=douDhHvfoViWmZth0cUX

# Diretório do banco de dados SQLite
# Em Railway/Render aponte para o volume persistente, ex: /data
DB_DIR=/data

# Horário do fetch diário (horário local do servidor)
SCHEDULE_HOUR=8
SCHEDULE_MINUTE=0

# Porta (Railway/Render injetam automaticamente — não altere)
# PORT=5000
